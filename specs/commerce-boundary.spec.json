{
  "schemaVersion": 1,
  "kind": "sdkwork.commerce.boundary.spec",
  "capability": "payment",
  "domain": "commerce",
  "role": "payment-executor",
  "ownedTables": [
    "commerce_payment_intent",
    "commerce_payment_attempt",
    "commerce_payment_record",
    "commerce_payment_method",
    "commerce_refund",
    "commerce_payment_provider_account",
    "commerce_payment_provider_credential",
    "commerce_payment_channel",
    "commerce_payment_webhook_event"
  ],
  "ownedApiPrefixes": {
    "app": [
      "/app/v3/api/payments",
      "/app/v3/api/refunds"
    ],
    "backend": [
      "/backend/v3/api/payments"
    ]
  },
  "deprecatedApiPrefixes": {
    "app": [
      "/app/v3/api/payments/webhooks"
    ],
    "reason": "PSP webhooks migrated to sdkwork-order"
  },
  "requiredForeignKeys": {
    "orderId": {
      "owner": "order",
      "table": "commerce_order",
      "requiredOn": [
        "payments.intents.create",
        "refunds.create",
        "owner-order pay"
      ],
      "note": "Payment stores orderId on intent/attempt; order orchestrates webhooks"
    }
  },
  "upstreamDependencies": [],
  "downstreamConsumers": [
    {
      "capability": "order",
      "purpose": "In-process PaymentWebhookStore + OwnerOrderPaymentStore ports"
    }
  ],
  "forbidden": [
    "crate dependency on sdkwork-order-service",
    "crate dependency on sdkwork-order-repository-sqlx",
    "import sdkwork_order_service or sdkwork_order_repository_sqlx from payment crates",
    "insert commerce_order",
    "insert commerce_order_item",
    "commerce_recharge_package CRUD",
    "direct account wallet adjustments",
    "recharges.* HTTP routes in payment app-api",
    "recharges.* service contract operations",
    "HTTP callback to order backend",
    "settlement orchestration in payment route crates",
    "JOIN commerce_order in payment webhook ingest",
    "settle_owner_order_after_payment_success",
    "OrderPointsRechargeFulfillmentClient",
    "POST /backend/v3/api/payments/owner-orders/{orderId}/confirmations"
  ],
  "migrationOut": {
    "status": "complete",
    "webhookShim": "crates/sdkwork-routes-payment-app-api/src/webhook_router.rs",
    "webhookBoundarySpec": "specs/commerce-payment-webhook.spec.json",
    "targetCapability": "order",
    "orderWebhookRoute": "POST /app/v3/api/orders/payments/webhooks/{providerCode}",
    "orderRechargeRoutePrefix": "/app/v3/api/recharges",
    "orderConfirmRoute": "POST /backend/v3/api/orders/{orderId}/payment_confirmations"
  },
  "implementationPhases": [
    {
      "id": "P1",
      "title": "Payment executor spec frozen",
      "status": "complete"
    },
    {
      "id": "P2",
      "title": "Order owns recharge; payment removes /recharges surface",
      "status": "complete",
      "blockedBy": ["O3"]
    },
    {
      "id": "P3",
      "title": "Remove payment recharge routes and insert_order",
      "status": "complete",
      "blockedBy": ["O5", "P2"]
    },
    {
      "id": "P4",
      "title": "Payment confirmation orchestrates order fulfillment saga",
      "status": "superseded",
      "supersededBy": "P6"
    },
    {
      "id": "P5",
      "title": "Webhook ingestion + automatic owner-order settlement in payment routes",
      "status": "superseded",
      "supersededBy": "P6"
    },
    {
      "id": "P6",
      "title": "Webhook + settlement migrated to order; payment 410 webhook shim",
      "status": "complete",
      "blockedBy": ["O13"],
      "deliverables": [
        "ingest_provider_webhook_sqlite/postgres (port only)",
        "PaymentWebhookAttemptContext (no order subject join)",
        "payment_webhook_router_deprecated 410 Gone",
        "removed owner_order_settlement and order_fulfillment_client"
      ]
    },
    {
      "id": "P7",
      "title": "Remove recharge proxy, manifest, and service types from payment",
      "status": "complete",
      "deliverables": [
        "deleted recharge_proxy_router.rs",
        "removed recharges.* from http_route_manifest",
        "removed recharge domain/commands/queries from sdkwork-payment-service"
      ]
    },
    {
      "id": "P8",
      "title": "Production hardening: envelopes, pagination, PSP enrichment, checkout, refund retry",
      "status": "complete",
      "deliverables": [
        "success_command_accepted on all write routes",
        "SQL pagination for app payment methods and backend lists",
        "PSP enrichment with callback_payload persistence",
        "GET /payments/checkout/{paymentId} re-enrichment",
        "refund PSP submit transient retry (3 attempts)",
        "build_app_payment_router store-only without sqlite::memory checkout placeholder"
      ]
    }
  ],
  "backendOperationIds": {
    "payments": [
      "webhookEvents.list",
      "webhookEvents.replay"
    ]
  },
  "cashierUrl": {
    "builder": "sdkwork-utils-rust::build_commerce_cashier_url",
    "baseUrlEnv": "SDKWORK_COMMERCE_CASHIER_BASE_URL"
  }
}
