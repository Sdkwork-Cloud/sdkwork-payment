{
  "schemaVersion": 1,
  "kind": "sdkwork.commerce.boundary.spec",
  "capability": "payment",
  "domain": "commerce",
  "role": "payment-executor",
  "ownedTables": [
    "commerce_payment_intent",
    "commerce_payment_attempt",
    "commerce_payment_record",
    "commerce_refund",
    "commerce_payment_provider_account",
    "commerce_payment_channel",
    "commerce_payment_webhook_event"
  ],
  "ownedApiPrefixes": {
    "app": [
      "/app/v3/api/payments"
    ],
    "backend": [
      "/backend/v3/api/payments"
    ]
  },
  "deprecatedApiPrefixes": {
    "app": [
      "/app/v3/api/recharges",
      "/app/v3/api/payments/webhooks"
    ],
    "reason": "Recharge and PSP webhooks migrated to sdkwork-order",
    "enableEnv": "SDKWORK_PAYMENT_ENABLE_RECHARGE_PROXY",
    "targetRemovalPhase": "P6"
  },
  "requiredForeignKeys": {
    "orderId": {
      "owner": "order",
      "table": "commerce_order",
      "requiredOn": [
        "payments.intents.create",
        "refunds.create",
        "owner-order pay"
      ],
      "note": "Payment stores orderId on intent/attempt; order orchestrates webhooks"
    }
  },
  "upstreamDependencies": [],
  "downstreamConsumers": [
    {
      "capability": "order",
      "purpose": "In-process PaymentWebhookStore + OwnerOrderPaymentStore ports"
    }
  ],
  "forbidden": [
    "insert commerce_order",
    "insert commerce_order_item",
    "commerce_recharge_package CRUD",
    "direct account wallet adjustments",
    "recharges.orders.create in target state",
    "HTTP callback to order backend",
    "settlement orchestration in payment route crates",
    "JOIN commerce_order in payment webhook ingest",
    "settle_owner_order_after_payment_success",
    "OrderPointsRechargeFulfillmentClient",
    "POST /backend/v3/api/payments/owner-orders/{orderId}/confirmations"
  ],
  "migrationOut": {
    "status": "complete",
    "rechargeProxy": "crates/sdkwork-routes-payment-app-api/src/recharge_proxy_router.rs",
    "webhookShim": "crates/sdkwork-routes-payment-app-api/src/webhook_router.rs",
    "targetCapability": "order",
    "orderWebhookRoute": "POST /app/v3/api/orders/payments/webhooks/{providerCode}",
    "orderConfirmRoute": "POST /backend/v3/api/orders/{orderId}/payment_confirmations"
  },
  "implementationPhases": [
    {
      "id": "P1",
      "title": "Payment executor spec frozen",
      "status": "complete"
    },
    {
      "id": "P2",
      "title": "Order owns recharge; payment /recharges proxy",
      "status": "complete",
      "blockedBy": ["O3"]
    },
    {
      "id": "P3",
      "title": "Remove payment recharge routes and insert_order",
      "status": "complete",
      "blockedBy": ["O5", "P2"]
    },
    {
      "id": "P4",
      "title": "Payment confirmation orchestrates order fulfillment saga",
      "status": "superseded",
      "supersededBy": "P6"
    },
    {
      "id": "P5",
      "title": "Webhook ingestion + automatic owner-order settlement in payment routes",
      "status": "superseded",
      "supersededBy": "P6"
    },
    {
      "id": "P6",
      "title": "Webhook + settlement migrated to order; payment 410 webhook shim",
      "status": "complete",
      "blockedBy": ["O13"],
      "deliverables": [
        "ingest_provider_webhook_sqlite/postgres (port only)",
        "PaymentWebhookAttemptContext (no order subject join)",
        "payment_webhook_router_deprecated 410 Gone",
        "removed owner_order_settlement and order_fulfillment_client"
      ]
    }
  ],
  "backendOperationIds": {
    "payments": [
      "payments.webhookEvents.list",
      "payments.webhookEvents.replay"
    ]
  },
  "cashierUrl": {
    "builder": "sdkwork-utils-rust::build_commerce_cashier_url",
    "baseUrlEnv": "SDKWORK_COMMERCE_CASHIER_BASE_URL"
  }
}
