{
  "schemaVersion": 1,
  "kind": "sdkwork.commerce.boundary.spec",
  "capability": "payment",
  "domain": "commerce",
  "role": "payment-executor",
  "ownedTables": [
    "commerce_payment_intent",
    "commerce_payment_attempt",
    "commerce_payment_record",
    "commerce_refund",
    "commerce_payment_provider_account",
    "commerce_payment_channel",
    "commerce_payment_webhook_event"
  ],
  "ownedApiPrefixes": {
    "app": [
      "/app/v3/api/payments"
    ],
    "backend": [
      "/backend/v3/api/payments"
    ]
  },
  "deprecatedApiPrefixes": {
    "app": [
      "/app/v3/api/recharges"
    ],
    "reason": "Migrate to sdkwork-order; opt-in proxy only",
    "enableEnv": "SDKWORK_PAYMENT_ENABLE_RECHARGE_PROXY",
    "targetRemovalPhase": "P5"
  },
  "requiredForeignKeys": {
    "orderId": {
      "owner": "order",
      "table": "commerce_order",
      "requiredOn": [
        "payments.intents.create",
        "refunds.create",
        "owner-order pay"
      ]
    }
  },
  "upstreamDependencies": [
    {
      "capability": "order",
      "purpose": "Validate order exists and payment_status transitions"
    }
  ],
  "downstreamConsumers": [],
  "forbidden": [
    "insert commerce_order",
    "insert commerce_order_item",
    "commerce_recharge_package CRUD",
    "direct account wallet adjustments",
    "recharges.orders.create in target state"
  ],
  "migrationOut": {
    "status": "complete",
    "rechargeProxy": "crates/sdkwork-routes-payment-app-api/src/recharge_proxy_router.rs",
    "targetCapability": "order"
  },
  "implementationPhases": [
    {
      "id": "P1",
      "title": "Payment executor spec frozen",
      "status": "complete"
    },
    {
      "id": "P2",
      "title": "Order owns recharge; payment /recharges proxy",
      "status": "complete",
      "blockedBy": ["O3"]
    },
    {
      "id": "P3",
      "title": "Remove payment recharge routes and insert_order",
      "status": "complete",
      "blockedBy": ["O5", "P2"]
    },
    {
      "id": "P4",
      "title": "Payment confirmation orchestrates order fulfillment saga",
      "status": "complete",
      "blockedBy": ["O6", "P3"],
      "deliverables": [
        "POST /backend/v3/api/payments/owner-orders/{orderId}/confirmations",
        "OrderPointsRechargeFulfillmentClient HTTP adapter",
        "confirm_owner_order_payment repository method"
      ]
    },
    {
      "id": "P5",
      "title": "Webhook ingestion + automatic owner-order settlement",
      "status": "complete",
      "blockedBy": ["P4"],
      "deliverables": [
        "ingest_provider_webhook_sqlite/postgres",
        "webhook_router settle_owner_order_after_payment_success",
        "OwnerOrderSettlementScope loaders"
      ]
    }
  ],
  "backendOperationIds": {
    "payments": [
      "payments.ownerOrders.confirmations.create"
    ]
  },
  "fulfillmentCallbacks": [
    {
      "operationId": "orders.pointsRecharge.fulfillments.create",
      "httpPath": "/backend/v3/api/orders/{orderId}/points_recharge/fulfillments",
      "targetCapability": "order",
      "triggeredBy": "payments.ownerOrders.confirmations.create"
    }
  ],
  "cashierUrl": {
    "builder": "sdkwork-utils-rust::build_commerce_cashier_url",
    "baseUrlEnv": "SDKWORK_COMMERCE_CASHIER_BASE_URL"
  }
}
