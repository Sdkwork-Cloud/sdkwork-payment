{
  "name": "@sdkwork/payment-pc-admin-core",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Payment PC backend-admin runtime: backend SDK inventory, admin module registry, and composition entry.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./sdk": {
      "types": "./src/sdk/index.ts",
      "import": "./src/sdk/index.ts",
      "default": "./src/sdk/index.ts"
    },
    "./modules": {
      "types": "./src/modules/index.ts",
      "import": "./src/modules/index.ts",
      "default": "./src/modules/index.ts"
    },
    "./host": {
      "types": "./src/host/index.ts",
      "import": "./src/host/index.ts",
      "default": "./src/host/index.ts"
    },
    "./session": {
      "types": "./src/session/index.ts",
      "import": "./src/session/index.ts",
      "default": "./src/session/index.ts"
    },
    "./composition": {
      "types": "./src/composition/index.ts",
      "import": "./src/composition/index.ts",
      "default": "./src/composition/index.ts"
    }
  },
  "files": ["src", "README.md"],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sdkwork/i18n-pc-react": "workspace:*",
    "@sdkwork/payment-contracts": "workspace:*",
    "@sdkwork/payment-sdk-ports": "workspace:*",
    "@sdkwork/payment-service": "workspace:*",
    "@sdkwork/ui-pc-react": "workspace:*",
    "lucide-react": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20.0.0",
    "react-dom": ">=18.2.0 <20.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "sdkwork": {
    "architecture": "pc-admin",
    "surface": "backend-admin",
    "capability": "payment-pc-admin-core",
    "domain": "payment",
    "packageType": "runtime",
    "status": "standard"
  }
}
