{
  "schemaVersion": 1,
  "kind": "sdkwork.component.spec",
  "component": {
    "name": "@sdkwork/payment-pc-admin-core",
    "displayName": "SDKWork Payment PC Admin Core",
    "version": "0.1.0",
    "type": "react-package",
    "root": "sdkwork-payment/apps/sdkwork-payment-pc/packages/sdkwork-payment-pc-admin-core",
    "domain": "payment",
    "declaredDomain": "commerce",
    "capability": "payment-pc-admin-core",
    "surface": "backend-admin",
    "status": "standard",
    "languages": ["typescript"],
    "generated": false,
    "private": true,
    "manifests": ["package.json"]
  },
  "canonicalSpecs": [
    {
      "file": "APP_PC_ARCHITECTURE_SPEC.md",
      "path": "../../../../../sdkwork-specs/APP_PC_ARCHITECTURE_SPEC.md",
      "purpose": "PC application root layout and backend-admin package naming."
    },
    {
      "file": "BACKEND_UI_SPEC.md",
      "path": "../../../../../sdkwork-specs/BACKEND_UI_SPEC.md",
      "purpose": "Backend-admin runtime composition and backend SDK inventory."
    }
  ],
  "contracts": {
    "sdkDependencies": [
      {
        "workspace": "@sdkwork/payment-backend-sdk",
        "permissionModuleId": "payment",
        "surface": "backend-api",
        "credentialMode": "authenticated-backend-admin"
      }
    ],
    "permissionComposition": {
      "inheritanceMode": "module-catalog-with-overrides",
      "moduleCatalogRefs": [
        {
          "moduleId": "payment",
          "manifestRef": "../../../../../specs/iam.module.manifest.json",
          "inheritPermissions": true,
          "inheritRoles": true
        }
      ],
      "bootstrapAccessTokenScope": {
        "inheritFrom": "sdkwork.app.config.json#backend.accessTokenPermissionScope",
        "supplement": [],
        "overrideReplace": false
      },
      "routePermissionHints": {
        "inheritFromOpenApi": true,
        "inheritFromModuleManifests": true,
        "overrides": []
      },
      "consumerPolicy": {
        "forbidLocalPermissionCatalogForDependencyDomains": true,
        "allowExplicitOverridesOnly": true,
        "allowFrontendHintsWithoutServerDuplication": true
      },
      "applicationModule": {
        "manifestRef": "../../../../../specs/iam.module.manifest.json"
      }
    },
    "publicExports": [".", "./sdk", "./modules", "./host", "./session", "./composition"],
    "runtimeEntrypoints": ["package.json#scripts.typecheck"],
    "sdkClients": ["@sdkwork/payment-backend-sdk"],
    "events": [],
    "configKeys": ["package.json#sdkwork"],
    "routeManifest": null
  },
  "integration": {
    "authority": "Root SDKWork specs remain authoritative. Local specs may extend but must not contradict them.",
    "dependencyPolicy": "Admin capability packages register through this core module registry.",
    "sdkPolicy": "Backend SDK clients are injected through admin-core composition boundaries.",
    "languagePolicy": "TypeScript packages follow workspace manifests while preserving the component contract."
  },
  "verification": {
    "commands": ["pnpm --filter @sdkwork/payment-pc-admin-core typecheck"]
  },
  "metadata": {
    "managedBy": "sdkwork-payment",
    "standardVersion": "2026-07-13"
  }
